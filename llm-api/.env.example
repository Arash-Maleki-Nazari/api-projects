# FastAPI Settings
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql://labeling_user:labeling_password@localhost:5432/labeling_db

# OpenAI / LLM
OPENAI_API_KEY=sk-your-api-key-here

# API Security
API_KEY_SECRET=your-api-key-here
RATE_LIMIT_PER_MINUTE=100

# Logging
LOG_FORMAT=json
